    <main class="dashboard-main">
      <h1>Add / Assign Teachers</h1>
      <p>Register teachers, create login accounts, and assign teachers to classes and subjects.</p>

      <section class="dashboard-section">
        <h2>Add New Teacher</h2>

        <form class="admin-form" id="teacherForm">
          <div>
            <label>Teacher ID</label>
            <input type="text" id="teacher_id" placeholder="Example: TCH004" required>
          </div>

          <div>
            <label>Branch / Location</label>
            <select id="teacher_branch_id" required>
              <option value="">Loading branches...</option>
            </select>
          </div>

          <div>
            <label>Teacher Full Name</label>
            <input type="text" id="teacher_full_name" placeholder="Enter teacher full name" required>
          </div>

          <div>
            <label>Ghana Card Number</label>
            <input type="text" id="teacher_ghana_card_number" placeholder="Example: GHA-444444444-4" required>
          </div>

          <div>
            <label>Phone Number</label>
            <input type="text" id="teacher_phone" placeholder="Enter phone number" required>
          </div>

          <div>
            <label>Email Address</label>
            <input type="email" id="teacher_email" placeholder="Enter email address">
          </div>

          <div>
            <label>Residential Address</label>
            <input type="text" id="teacher_address" placeholder="Enter address">
          </div>

          <div>
            <label>Account Status</label>
            <select id="teacher_status">
              <option value="active">Active</option>
              <option value="inactive">Inactive</option>
              <option value="locked">Locked</option>
              <option value="disabled">Disabled</option>
            </select>
          </div>

          <button type="submit">Add Teacher</button>
        </form>
      </section>

      <section class="dashboard-section">
        <h2>Assign Teacher to Class / Subject</h2>

        <form class="admin-form" id="teacherAssignForm">
          <div>
            <label>Select Teacher</label>
            <select id="assign_teacher_id" required>
              <option value="">Loading teachers...</option>
            </select>
          </div>

          <div>
            <label>Branch / Location</label>
            <select id="assign_branch_id" required>
              <option value="">Loading branches...</option>
            </select>
          </div>

          <div>
            <label>Assign Class</label>
            <select id="assign_class_id" required>
              <option value="">Loading classes...</option>
            </select>
          </div>

          <div>
            <label>Subject</label>
            <input type="text" id="assign_subject" placeholder="Example: Mathematics" required>
          </div>

          <div>
            <label>Role</label>
            <select id="assign_role">
              <option value="Class Teacher">Class Teacher</option>
              <option value="Subject Teacher">Subject Teacher</option>
            </select>
          </div>

          <div>
            <label>Academic Year</label>
            <input type="text" id="assign_academic_year" value="2025/2026">
          </div>

          <button type="submit">Assign Teacher</button>
        </form>
      </section>

      <section class="dashboard-section">
        <h2>Teacher List</h2>

        <table class="data-table">
          <thead>
            <tr>
              <th>Branch</th>
              <th>Teacher ID</th>
              <th>Name</th>
              <th>Ghana Card</th>
              <th>Phone</th>
              <th>Email</th>
              <th>Assigned Class</th>
              <th>Assigned Subject</th>
              <th>Status</th>
              <th>Action</th>
            </tr>
          </thead>

          <tbody id="teacherTableBody">
            <tr>
              <td colspan="10">Loading teachers...</td>
            </tr>
          </tbody>
        </table>
      </section>

    </main>

