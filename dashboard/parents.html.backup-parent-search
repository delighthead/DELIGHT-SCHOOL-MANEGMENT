    <main class="dashboard-main">
      <h1>Add Parents</h1>
      <p>Register parents, link them to a branch/location, and create their login account.</p>

      <section class="dashboard-section">
        <h2>Add New Parent</h2>

        <form class="admin-form" id="parentForm">
          <div>
            <label>Branch / Location</label>
            <select id="parent_branch_id" required>
              <option value="">Loading branches...</option>
            </select>
          </div>

          <div>
            <label>Parent Full Name</label>
            <input type="text" id="parent_full_name" placeholder="Enter parent full name" required>
          </div>

          <div>
            <label>Ghana Card Number</label>
            <input type="text" id="parent_ghana_card" placeholder="Example: GHA-111111111-1" required>
          </div>

          <div>
            <label>Phone Number</label>
            <input type="text" id="parent_phone" placeholder="Example: 0243334444" required>
          </div>

          <div>
            <label>Email Address</label>
            <input type="email" id="parent_email" placeholder="Enter email address">
          </div>

          <div>
            <label>Residential Address</label>
            <input type="text" id="parent_address" placeholder="Enter residential address">
          </div>

          <div class="form-group">
            <label for="parent_status">Account Status</label>
            <select id="parent_status">
              <option value="active">Active</option>
              <option value="disabled">Disabled</option>
              <option value="locked">Locked</option>
            </select>
          </div>

          <button type="submit">Add Parent</button>
        </form>
      </section>

      <section class="dashboard-section">
        <h2>Parent List</h2>

        <table class="data-table">
          <thead>
            <tr>
              <th>Branch</th>
              <th>Parent Name</th>
              <th>Ghana Card</th>
              <th>Phone</th>
              <th>Email</th>
              <th>Address</th>
              <th>Status</th>
              <th>Action</th>
            </tr>
          </thead>

          <tbody id="parentTableBody">
            <tr>
              <td colspan="8">Loading parents...</td>
            </tr>
          </tbody>
        </table>
      </section>

    </main>

  </div>

